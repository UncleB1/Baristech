# BarisTech Environment Variables
# Copy this file to .env.local and fill in your actual values

# ============================================
# API Configuration - REQUIRED
# ============================================

# Anthropic Claude API
NEXT_PUBLIC_ANTHROPIC_API_URL=https://api.anthropic.com/v1/messages
NEXT_PUBLIC_ANTHROPIC_API_KEY=sk-ant-YOUR_API_KEY_HERE
NEXT_PUBLIC_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ============================================
# Authentication - REQUIRED
# ============================================

# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=YOUR_RANDOM_SECRET_HERE
NEXTAUTH_URL=http://localhost:3000

# ============================================
# Database - Choose One (Future)
# ============================================

# If using Firebase:
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# If using Supabase:
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# If using custom backend:
# DATABASE_URL=
# DATABASE_SECRET=

# ============================================
# Feature Flags
# ============================================

NEXT_PUBLIC_ENABLE_AI=true
NEXT_PUBLIC_ENABLE_BILLING=true
NEXT_PUBLIC_ENABLE_TIME_TRACKING=true
NEXT_PUBLIC_ENABLE_DOCUMENT_UPLOAD=true

# ============================================
# Email Configuration (Optional - for future)
# ============================================

# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# ============================================
# Monitoring & Logging (Optional - for future)
# ============================================

# SENTRY_DSN=
# LOG_LEVEL=info

# ============================================
# Notes
# ============================================
# - Keep this file in .gitignore (DO NOT COMMIT)
# - Never share NEXTAUTH_SECRET or API keys
# - Use different values for development, staging, production
# - Rotate secrets regularly in production
